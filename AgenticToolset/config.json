{
  "project_name": "AgenticToolset",
  "version": "1.0.0",
  "description": "Portable AI development toolkit. Drop into any project to enable structured multi-agent workflows, automated analysis, and comprehensive logging.",

  "model_config": {
    "provider": "anthropic",
    "models": {
      "anthropic": {
        "model_name": "claude-opus-4-6",
        "max_tokens": 16000,
        "env_var": "ANTHROPIC_API_KEY"
      },
      "gemini": {
        "model_name": "gemini-2.5-pro",
        "max_tokens": 16000,
        "env_var": "GOOGLE_GEMINI_API_KEY"
      }
    }
  },

  "orchestration_logic": {
    "mode": "hierarchical",
    "max_loops": 15,
    "phases": ["SCAN", "PLAN", "EXECUTE", "REVIEW", "DELIVER"],
    "approval_checkpoints": ["after_plan", "after_execute"],
    "fallback_behavior": {
      "on_error": "log_and_escalate",
      "on_loop_limit": "summarize_progress_and_halt",
      "on_tool_failure": "retry_once_then_skip"
    }
  },

  "agent_registry": {
    "AGNT_DIR_01": {"name": "Orchestrator", "file": "agents/orchestrator.md"},
    "AGNT_ARC_02": {"name": "Architect", "file": "agents/architect.md"},
    "AGNT_COD_03": {"name": "Implementer", "file": "agents/implementer.md"},
    "AGNT_REV_04": {"name": "Reviewer", "file": "agents/reviewer.md"},
    "AGNT_DBG_05": {"name": "Debugger", "file": "agents/debugger.md"},
    "AGNT_RES_06": {"name": "Researcher", "file": "agents/researcher.md"},
    "AGNT_TST_07": {"name": "Tester", "file": "agents/tester.md"},
    "AGNT_DOC_08": {"name": "Doc Writer", "file": "agents/doc_writer.md"},
    "AGNT_WEB_09": {"name": "Web Researcher", "file": "agents/web_researcher.md"},
    "AGNT_WSC_10": {"name": "Web Scraper Specialist", "file": "agents/web_scraper_specialist.md"}
  },

  "tool_registry": {
    "log_manager": {
      "def": "tools/defs/log_manager.json",
      "impl": "tools/python/log_manager.py"
    },
    "project_scanner": {
      "def": "tools/defs/project_scanner.json",
      "impl": "tools/python/project_scanner.py"
    },
    "dependency_analyzer": {
      "def": "tools/defs/dependency_analyzer.json",
      "impl": "tools/python/dependency_analyzer.py"
    },
    "code_analyzer": {
      "def": "tools/defs/code_analyzer.json",
      "impl": "tools/python/code_analyzer.py"
    },
    "session_manager": {
      "def": "tools/defs/session_manager.json",
      "impl": "tools/python/session_manager.py"
    },
    "metrics_collector": {
      "def": "tools/defs/metrics_collector.json",
      "impl": "tools/python/metrics_collector.py"
    },
    "scaffold_generator": {
      "def": "tools/defs/scaffold_generator.json",
      "impl": "tools/python/scaffold_generator.py"
    },
    "web_researcher": {
      "def": "tools/defs/web_researcher.json",
      "impl": "tools/python/web_researcher.py"
    },
    "web_scraper": {
      "def": "tools/defs/web_scraper.json",
      "impl": "tools/python/web_scraper.py"
    }
  },

  "logging": {
    "master_log": "logs/master.jsonl",
    "session_log_dir": "logs/sessions",
    "log_level": "INFO",
    "max_log_size_mb": 50,
    "rotation_count": 5,
    "log_tool_invocations": true,
    "log_llm_decisions": true,
    "log_agent_switches": true
  },

  "quality_standards": {
    "min_quality_score": 7,
    "require_review_before_commit": true,
    "require_tests_for_new_code": true,
    "max_function_complexity": 15,
    "max_file_length_lines": 500
  },

  "workspace": {
    "session_dir": "workspace",
    "output_dir": "workspace/output",
    "temp_dir": "workspace/temp",
    "session_id_format": "YYYYMMDD_HHMMSS"
  },

  "global_settings": {
    "auto_scan_on_init": true,
    "auto_log": true,
    "sandbox_execution": true,
    "execution_timeout_seconds": 30,
    "max_file_read_lines": 5000
  }
}
