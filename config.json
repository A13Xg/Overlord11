  "orchestration": {
    "max_loops": 10,
    "max_retries_per_agent": 3,
    "retry_on_empty_output": true,
    "always_review_before_delivery": true,
    "fallback_provider_order": [
      "gemini",
      "openai",
      "anthropic"
    ],
    "phases": [
      "intake",
      "research",
      "planning",
      "execution",
      "review",
      "delivery"
    ],
    "memory_file": "Consciousness.md",
    "log_sessions": true,
    "log_dir": "logs/"
  },
  "quality": {
    "min_test_coverage": 80,
    "require_tests_for_new_code": true,
    "require_reviewer_approval": true,
    "max_complexity_per_function": 10,
    "security_scan_enabled": true,
    "require_docstrings": true
  },
  "workspace": {
    "root": "workspace/",
    "session_id_format": "YYYYMMDD_HHmmss",
    "max_sessions_retained": 50,
    "auto_cleanup_days": 30
  },
  "logging": {
    "level": "info",
    "log_dir": "logs/",
    "log_format": "json",
    "include_tool_calls": true,
    "include_agent_outputs": true,
    "rotate_daily": true,
    "max_log_files": 30
  },
  "ui_defaults": {
    "_comment": "Controls HTML/CSS output quality — applies to all AI providers",
    "design_system_required": true,
    "preferred_styles": [
      "aurora-gradient",
      "glassmorphism",
      "ultraviolet",
      "neobrutalism",
      "biomimetic"
    ],
    "fallback_styles": [
      "minimal-zen",
      "data-dense",
      "soft-ui",
      "editorial",
      "brutalist",
      "retro-terminal"
    ],
    "publisher_preferred_themes": [
      "aurora",
      "ultraviolet",
      "neobrutalism"
    ],
    "no_basic_generic_html": true,
    "verbose_ui_required": true
  }
}