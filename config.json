{
  "version": "2.0.0",
  "name": "Overlord11",
  "description": "Provider-agnostic multi-agent LLM toolset",

  "providers": {
    "active": "anthropic",
    "anthropic": {
      "model": "claude-opus-4-5",
      "api_key_env": "ANTHROPIC_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://api.anthropic.com/v1"
    },
    "gemini": {
      "model": "gemini-2.5-pro",
      "api_key_env": "GOOGLE_GEMINI_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://generativelanguage.googleapis.com/v1beta"
    },
    "openai": {
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://api.openai.com/v1"
    }
  },

  "agents": {
    "orchestrator": {
      "id": "OVR_DIR_01",
      "name": "Orchestrator",
      "file": "agents/orchestrator.md",
      "description": "Master coordinator — delegates to all other agents",
      "entry_point": true,
      "can_delegate_to": ["researcher", "coder", "analyst", "writer", "reviewer"]
    },
    "researcher": {
      "id": "OVR_RES_02",
      "name": "Researcher",
      "file": "agents/researcher.md",
      "description": "Web research, information gathering, source verification",
      "entry_point": false,
      "tools": ["web_fetch", "web_scraper", "read_file", "list_directory", "glob", "search_file_content", "save_memory", "project_scanner"]
    },
    "coder": {
      "id": "OVR_COD_03",
      "name": "Coder",
      "file": "agents/coder.md",
      "description": "Code generation, debugging, testing, refactoring",
      "entry_point": false,
      "tools": ["read_file", "write_file", "replace", "run_shell_command", "code_analyzer", "project_scanner", "scaffold_generator", "git_tool", "search_file_content", "glob"]
    },
    "analyst": {
      "id": "OVR_ANL_04",
      "name": "Analyst",
      "file": "agents/analyst.md",
      "description": "Data analysis, summarization, pattern recognition",
      "entry_point": false,
      "tools": ["read_file", "calculator", "code_analyzer", "project_scanner", "search_file_content", "glob", "save_memory"]
    },
    "writer": {
      "id": "OVR_WRT_05",
      "name": "Writer",
      "file": "agents/writer.md",
      "description": "Documentation, reports, content creation",
      "entry_point": false,
      "tools": ["read_file", "write_file", "replace", "list_directory", "glob"]
    },
    "reviewer": {
      "id": "OVR_REV_06",
      "name": "Reviewer",
      "file": "agents/reviewer.md",
      "description": "QA, code review, proofreading, validation",
      "entry_point": false,
      "tools": ["read_file", "code_analyzer", "run_shell_command", "search_file_content", "glob"]
    }
  },

  "tools": {
    "read_file": {
      "def": "tools/defs/read_file.json",
      "impl": "tools/python/read_file.py"
    },
    "write_file": {
      "def": "tools/defs/write_file.json",
      "impl": "tools/python/write_file.py"
    },
    "list_directory": {
      "def": "tools/defs/list_directory.json",
      "impl": "tools/python/list_directory.py"
    },
    "glob": {
      "def": "tools/defs/glob.json",
      "impl": "tools/python/glob_tool.py"
    },
    "search_file_content": {
      "def": "tools/defs/search_file_content.json",
      "impl": "tools/python/search_file_content.py"
    },
    "replace": {
      "def": "tools/defs/replace.json",
      "impl": null
    },
    "run_shell_command": {
      "def": "tools/defs/run_shell_command.json",
      "impl": "tools/python/run_shell_command.py"
    },
    "web_fetch": {
      "def": "tools/defs/web_fetch.json",
      "impl": "tools/python/web_fetch.py"
    },
    "git_tool": {
      "def": "tools/defs/git_tool.json",
      "impl": "tools/python/git_tool.py"
    },
    "calculator": {
      "def": "tools/defs/calculator.json",
      "impl": "tools/python/calculator_tool.py"
    },
    "save_memory": {
      "def": "tools/defs/save_memory.json",
      "impl": "tools/python/save_memory_tool.py"
    },
    "web_scraper": {
      "def": "tools/defs/web_scraper.json",
      "impl": "tools/python/web_scraper.py"
    },
    "project_scanner": {
      "def": "tools/defs/project_scanner.json",
      "impl": "tools/python/project_scanner.py"
    },
    "code_analyzer": {
      "def": "tools/defs/code_analyzer.json",
      "impl": "tools/python/code_analyzer.py"
    }
  },

  "orchestration": {
    "max_loops": 10,
    "max_retries_per_agent": 3,
    "retry_on_empty_output": true,
    "always_review_before_delivery": true,
    "fallback_provider_order": ["anthropic", "gemini", "openai"],
    "phases": [
      "intake",
      "research",
      "planning",
      "execution",
      "review",
      "delivery"
    ],
    "memory_file": "Consciousness.md",
    "log_sessions": true,
    "log_dir": "logs/"
  },

  "quality": {
    "min_test_coverage": 80,
    "require_tests_for_new_code": true,
    "require_reviewer_approval": true,
    "max_complexity_per_function": 10,
    "security_scan_enabled": true,
    "require_docstrings": true
  },

  "workspace": {
    "root": "workspace/",
    "session_id_format": "YYYYMMDD_HHmmss",
    "max_sessions_retained": 50,
    "auto_cleanup_days": 30
  },

  "logging": {
    "level": "info",
    "log_dir": "logs/",
    "log_format": "json",
    "include_tool_calls": true,
    "include_agent_outputs": true,
    "rotate_daily": true,
    "max_log_files": 30
  }
}
