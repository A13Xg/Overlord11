{
  "version": "2.3.0",
  "name": "Overlord11",
  "description": "Provider-agnostic multi-agent LLM toolset",
  "providers": {
    "active": "gemini",
    "anthropic": {
      "model": "claude-opus-4-5",
      "available_models": {
        "claude-opus-4-5": "Most capable — best for complex reasoning, long-form generation, nuanced tasks",
        "claude-opus-4-0": "Previous Opus generation — strong capability, slightly lower cost",
        "claude-sonnet-4-5": "Balanced speed + capability — recommended default for most tasks",
        "claude-sonnet-3-7": "Extended thinking variant — ideal for step-by-step reasoning tasks",
        "claude-haiku-3-5": "Fast and lightweight — best for simple Q&A, classification, quick responses",
        "claude-haiku-3-0": "Smallest / cheapest — high-throughput, latency-sensitive workloads"
      },
      "api_key_env": "ANTHROPIC_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://api.anthropic.com/v1"
    },
    "gemini": {
      "model": "gemini-3.1-pro-preview",
      "available_models": {
        "gemini-3.1-pro-preview": "Latest Pro Preview — advanced reasoning, tool use, 1M context, agentic workflows (Feb 2026)",
        "gemini-3-flash-preview": "Latest Flash Preview — frontier multimodal, strongest agentic/vibe-coding, 1M context (Dec 2025)",
        "gemini-3.1-flash-lite-preview": "Latest Flash-Lite Preview — fastest budget model, 1M context, low-latency (Mar 2026)",
        "gemini-2.5-pro": "Stable Pro — deep reasoning, 1M context, multimodal, best for complex tasks",
        "gemini-2.5-flash": "Stable Flash — best price-performance, low-latency, high-volume tasks",
        "gemini-2.5-flash-lite": "Stable Flash-Lite — fastest/cheapest in 2.5 family, budget high-frequency tasks",
        "gemini-2.0-flash": "Previous Flash (deprecated) — fast, 1M context, native tool use",
        "gemini-1.5-pro": "Legacy Pro — 2M context window, good for document-heavy tasks",
        "gemini-1.5-flash": "Legacy Flash — cost-effective for simpler tasks",
        "gemma-4-31b-it": "Gemma 4 31B — dense, 256K context, frontier reasoning and coding (Apr 2026)",
        "gemma-4-26b-a4b-it": "Gemma 4 26B MoE (A4B active) — fast MoE inference, 256K context (Apr 2026)",
        "gemma-4-e4b-it": "Gemma 4 E4B (4.5B effective) — multimodal with audio, 128K context, laptop/server",
        "gemma-4-e2b-it": "Gemma 4 E2B (2.3B effective) — multimodal with audio, 128K context, on-device",
        "gemma-3-27b-it": "Gemma 3 27B — 128K context, multilingual 140+ languages, vision+text",
        "gemma-3-12b-it": "Gemma 3 12B — balanced capability, 128K context, multimodal",
        "gemma-3-4b-it": "Gemma 3 4B — lightweight, 128K context, edge deployment",
        "gemma-3-1b-it": "Gemma 3 1B — smallest Gemma 3, 32K context, ultra-low-resource",
        "gemma-2-27b-it": "Gemma 2 27B — previous gen large, strong general-purpose",
        "gemma-2-9b-it": "Gemma 2 9B — previous gen mid, efficient general use",
        "gemma-2-2b-it": "Gemma 2 2B — previous gen compact, minimal resource footprint"
      },
      "api_key_env": "GOOGLE_GEMINI_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://generativelanguage.googleapis.com/v1beta"
    },
    "openai": {
      "model": "gpt-4o",
      "available_models": {
        "gpt-4o": "Most capable GPT-4 class — best for complex tasks, vision, tool use",
        "gpt-4o-mini": "Fast and cheap GPT-4 class — excellent for most everyday tasks",
        "gpt-4-turbo": "Previous flagship — 128k context, strong reasoning",
        "o3": "OpenAI reasoning model — best for multi-step logic and math",
        "o3-mini": "Lightweight reasoning model — fast chain-of-thought at lower cost",
        "o4-mini": "Latest reasoning mini — strong coding and math, very fast",
        "gpt-3.5-turbo": "Legacy lightweight model — cheapest option for simple completions"
      },
      "api_key_env": "OPENAI_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://api.openai.com/v1"
    }
  },
  "agents": {
    "orchestrator": {
      "id": "OVR_DIR_01",
      "name": "Orchestrator",
      "file": "agents/orchestrator.md",
      "description": "Master coordinator — delegates to all other agents",
      "entry_point": true,
      "can_delegate_to": [
        "researcher",
        "coder",
        "analyst",
        "writer",
        "reviewer",
        "publisher",
        "cleanup"
      ]
    },
    "researcher": {
      "id": "OVR_RES_02",
      "name": "Researcher",
      "file": "agents/researcher.md",
      "description": "Web research, information gathering, source verification",
      "entry_point": false,
      "tools": [
        "web_fetch",
        "web_scraper",
        "read_file",
        "list_directory",
        "glob",
        "search_file_content",
        "save_memory",
        "project_scanner",
        "consciousness_tool",
        "error_handler"
      ]
    },
    "coder": {
      "id": "OVR_COD_03",
      "name": "Coder",
      "file": "agents/coder.md",
      "description": "Code generation, debugging, testing, refactoring",
      "entry_point": false,
      "tools": [
        "read_file",
        "write_file",
        "replace",
        "run_shell_command",
        "code_analyzer",
        "project_scanner",
        "scaffold_generator",
        "git_tool",
        "search_file_content",
        "glob",
        "task_manager",
        "error_logger",
        "project_docs_init",
        "launcher_generator",
        "ui_design_system",
        "execute_python"
      ]
    },
    "analyst": {
      "id": "OVR_ANL_04",
      "name": "Analyst",
      "file": "agents/analyst.md",
      "description": "Data analysis, summarization, pattern recognition",
      "entry_point": false,
      "tools": [
        "read_file",
        "calculator",
        "code_analyzer",
        "project_scanner",
        "search_file_content",
        "glob",
        "save_memory",
        "consciousness_tool",
        "response_formatter",
        "file_converter"
      ]
    },
    "writer": {
      "id": "OVR_WRT_05",
      "name": "Writer",
      "file": "agents/writer.md",
      "description": "Documentation, reports, content creation",
      "entry_point": false,
      "tools": [
        "read_file",
        "write_file",
        "replace",
        "list_directory",
        "glob",
        "task_manager",
        "consciousness_tool",
        "response_formatter",
        "file_converter"
      ]
    },
    "reviewer": {
      "id": "OVR_REV_06",
      "name": "Reviewer",
      "file": "agents/reviewer.md",
      "description": "QA, code review, proofreading, validation",
      "entry_point": false,
      "tools": [
        "read_file",
        "code_analyzer",
        "run_shell_command",
        "search_file_content",
        "glob",
        "cleanup_tool",
        "ui_design_system",
        "consciousness_tool",
        "error_handler"
      ]
    },
    "publisher": {
      "id": "OVR_PUB_07",
      "name": "Publisher",
      "file": "agents/publisher.md",
      "description": "Tiered output formatter — markdown for mid-complexity, styled self-contained HTML for detailed/visual requests",
      "entry_point": false,
      "tools": [
        "read_file",
        "write_file",
        "replace",
        "publisher_tool"
      ]
    },
    "cleanup": {
      "id": "OVR_CLN_08",
      "name": "Cleanup",
      "file": "agents/cleanup.md",
      "description": "Pre-deployment sanity check — scans for secrets, removes temp files, validates structure",
      "entry_point": false,
      "tools": [
        "cleanup_tool",
        "read_file",
        "glob",
        "search_file_content",
        "run_shell_command"
      ]
    }
  },
  "tools": {
    "read_file": {
      "def": "tools/defs/read_file.json",
      "impl": "tools/python/read_file.py"
    },
    "write_file": {
      "def": "tools/defs/write_file.json",
      "impl": "tools/python/write_file.py"
    },
