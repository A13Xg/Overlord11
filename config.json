{
  "version": "2.3.1",
  "name": "Overlord11",
  "description": "Provider-agnostic multi-agent LLM toolset",
  "providers": {
    "active": "gemini",
    "anthropic": {
      "model": "claude-opus-4-5",
      "available_models": {
        "claude-opus-4-5": "Most capable — best for complex reasoning, long-form generation, nuanced tasks",
        "claude-opus-4-0": "Previous Opus generation — strong capability, slightly lower cost",
        "claude-sonnet-4-5": "Balanced speed + capability — recommended default for most tasks",
        "claude-sonnet-3-7": "Extended thinking variant — ideal for step-by-step reasoning tasks",
        "claude-haiku-3-5": "Fast and lightweight — best for simple Q&A, classification, quick responses",
        "claude-haiku-3-0": "Smallest / cheapest — high-throughput, latency-sensitive workloads"
      },
      "api_key_env": "ANTHROPIC_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://api.anthropic.com/v1"
    },
    "gemini": {
      "model": "gemini-3.1-flash-lite-preview",
      "available_models": {
        "gemini-3.1-flash-lite-preview": "Default — ultra-fast, cost-effective, latest Flash Lite generation",
        "gemini-3.1-flash-preview": "Fast + high quality — latest Flash generation preview",
        "gemini-3.1-pro-preview": "Most capable 3.1 — complex reasoning, long context",
        "gemini-2.5-pro": "Previous Pro — 1M token context, multimodal, complex tasks",
        "gemini-2.5-flash": "Previous Flash — fast + capable, best balance",
        "gemini-2.5-flash-lite": "Ultra-fast / cheapest — high-volume, latency-critical",
        "gemini-2.0-pro": "Legacy Pro — strong reasoning, multimodal",
        "gemini-2.0-flash": "Legacy Flash — reliable, widely supported",
        "gemini-1.5-pro": "Legacy long-context — 2M token window",
        "gemini-1.5-flash": "Legacy fast — cost-effective for simple tasks"
      },
      "api_key_env": "GOOGLE_GEMINI_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://generativelanguage.googleapis.com/v1beta"
    },
    "openai": {
      "model": "gpt-4o",
      "available_models": {
        "gpt-4o": "Most capable GPT-4 class — best for complex tasks, vision, tool use",
        "gpt-4o-mini": "Fast and cheap GPT-4 class — excellent for most everyday tasks",
        "gpt-4-turbo": "Previous flagship — 128k context, strong reasoning",
        "o3": "OpenAI reasoning model — best for multi-step logic and math",
        "o3-mini": "Lightweight reasoning model — fast chain-of-thought at lower cost",
        "o4-mini": "Latest reasoning mini — strong coding and math, very fast",
        "gpt-3.5-turbo": "Legacy lightweight model — cheapest option for simple completions"
      },
      "api_key_env": "OPENAI_API_KEY",
      "max_tokens": 8192,
      "temperature": 0.7,
      "top_p": 1.0,
      "api_base": "https://api.openai.com/v1"
    }
  },
  "agents": {
    "orchestrator": {
      "id": "OVR_DIR_01",
      "name": "Orchestrator",
      "file": "agents/orchestrator.md",
      "description": "Master coordinator — delegates to all other agents",
      "entry_point": true,
      "can_delegate_to": [
        "researcher",
        "coder",
        "analyst",
        "writer",
        "reviewer",
        "publisher",
        "cleanup"
      ]
    },
    "researcher": {
      "id": "OVR_RES_02",
      "name": "Researcher",
      "file": "agents/researcher.md",
      "description": "Web research, information gathering, source verification",
      "entry_point": false,
      "tools": [
        "web_fetch",
        "web_scraper",
        "read_file",
        "list_directory",
        "glob",
        "search_file_content",
        "save_memory",
        "project_scanner",
        "consciousness_tool",
        "error_handler"
      ]
    },
    "coder": {
      "id": "OVR_COD_03",
      "name": "Coder",
      "file": "agents/coder.md",
      "description": "Code generation, debugging, testing, refactoring",
      "entry_point": false,
      "tools": [
        "read_file",
        "write_file",
        "replace",
        "run_shell_command",
        "code_analyzer",
        "project_scanner",
        "scaffold_generator",
        "git_tool",
        "search_file_content",
        "glob",
        "task_manager",
        "error_logger",
        "project_docs_init",
        "launcher_generator",
        "ui_design_system"
      ]
    },
    "analyst": {
      "id": "OVR_ANL_04",
      "name": "Analyst",
      "file": "agents/analyst.md",
      "description": "Data analysis, summarization, pattern recognition",
      "entry_point": false,
      "tools": [
        "read_file",
        "calculator",
        "code_analyzer",
        "project_scanner",
        "search_file_content",
        "glob",
        "save_memory",
        "consciousness_tool",
        "response_formatter",
        "file_converter"
      ]
    },
    "writer": {
      "id": "OVR_WRT_05",
      "name": "Writer",
      "file": "agents/writer.md",
      "description": "Documentation, reports, content creation",
      "entry_point": false,
      "tools": [
        "read_file",
        "write_file",
        "replace",
        "list_directory",
        "glob",
        "task_manager",
        "consciousness_tool",
        "response_formatter",
        "file_converter"
      ]
    },
    "reviewer": {
      "id": "OVR_REV_06",
      "name": "Reviewer",
      "file": "agents/reviewer.md",
      "description": "QA, code review, proofreading, validation",
      "entry_point": false,
      "tools": [
        "read_file",
        "code_analyzer",
        "run_shell_command",
        "search_file_content",
        "glob",
        "cleanup_tool",
        "ui_design_system",
        "consciousness_tool",
        "error_handler"
      ]
    },
    "publisher": {
      "id": "OVR_PUB_07",
      "name": "Publisher",
      "file": "agents/publisher.md",
      "description": "Tiered output formatter — markdown for mid-complexity, styled self-contained HTML for detailed/visual requests",
      "entry_point": false,
      "tools": [
        "read_file",
        "write_file",
        "replace",
        "publisher_tool",
        "response_formatter"
      ]
    },
    "cleanup": {
      "id": "OVR_CLN_08",
      "name": "Cleanup",
      "file": "agents/cleanup.md",
      "description": "Pre-deployment sanity check — scans for secrets, removes temp files, validates structure",
      "entry_point": false,
      "tools": [
        "cleanup_tool",
        "read_file",
        "glob",
        "search_file_content",
        "run_shell_command"
      ]
    }
  },
  "tools": {
    "read_file": {
      "def": "tools/defs/read_file.json",
